{
  "permissions": {
    "allow": [
      "Bash(ls -la cli*)",
      "Bash(bun run:*)",
      "Bash(mkdir -p ~/.claude)",
      "Bash(~/.claude/settings.json)",
      "Bash(./cli-enhanced.exe --version)",
      "Bash(./cli.exe --version)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(gh repo:*)",
      "Bash(curl:*)",
      "Bash(./cli-dev skills:*)",
      "Skill(design-md)",
      "Bash(xargs ls:*)",
      "Bash(find . -type f -name *.json -o -name *.ts -o -name *.tsx -o -name *.md)",
      "Bash(wc -l src/**/*.ts src/**/*.tsx)",
      "Bash(xargs wc:*)"
    ]
  }
}
